# Copy to frontend/.env

# Local dev — Vite proxies /api → backend
VITE_API_URL=/api/v1
VITE_DEV_API_PROXY=http://localhost:5000
VITE_SOCKET_URL=

# Production — frontend and backend on different hosts (set before npm run build)
# VITE_API_URL=https://your-backend.example.com/api/v1
# VITE_SOCKET_URL=https://your-backend.example.com

# Also set on the backend: FRONTEND_URL=https://your-frontend.example.com

VITE_APP_NAME=PNMC Management System
