# Copy to frontend/.env — all frontend config lives here only.

# Local dev — Vite proxies /api → backend (see VITE_DEV_API_PROXY)
VITE_API_URL=/api
VITE_DEV_API_PROXY=http://localhost:5000

# Production (Vercel) — set in Project → Settings → Environment Variables
# VITE_API_URL=https://pnmc-backend.vercel.app/api

VITE_APP_NAME=PNMC Management System
