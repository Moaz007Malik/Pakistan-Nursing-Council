# =============================================================================
# VERCEL ENVIRONMENT VARIABLES
# =============================================================================

# --- REQUIRED ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
FRONTEND_URL=https://your-project.vercel.app
NODE_ENV=production
VITE_API_URL=/api/v1
VITE_SOCKET_URL=

# --- PAYMENTS ---
PAYMENTS_ENABLED=false
# STRIPE_SECRET_KEY=  (only when PAYMENTS_ENABLED=true)

# --- FILE UPLOADS (required on Vercel for document uploads) ---
# Recommended: Cloudinary (free tier)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=pnmc

# Alternative: Cloudflare R2
# STORAGE_PROVIDER=s3_compatible
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=pnmc-documents
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true

# --- OPTIONAL ---
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
