# =============================================================================
# VERCEL ENVIRONMENT VARIABLES
# =============================================================================

# --- REQUIRED (backend project: pnmc-backend) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority
MONGODB_DNS_SRV=false
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_URI_DIRECT=<run: cd backend && npm run mongo:direct-uri — paste output here>
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
FRONTEND_URL=https://your-frontend.vercel.app
# Optional extra origins (comma-separated)
CORS_ORIGINS=https://pnmc-pjt.vercel.app
NODE_ENV=production

# Frontend (separate deploy) — set on the frontend project / frontend/.env before build
VITE_API_URL=https://your-backend.vercel.app/api
VITE_SOCKET_URL=https://your-backend.vercel.app

# Monorepo/same-origin only (single Vercel project with API rewrites):
# VITE_API_URL=/api
# VITE_SOCKET_URL=

# --- PAYMENTS ---
PAYMENTS_ENABLED=false
# STRIPE_SECRET_KEY=  (only when PAYMENTS_ENABLED=true)

# --- FILE UPLOADS (required on Vercel for document uploads) ---
# Recommended: Cloudinary (free tier)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=pnmc

# Alternative: Cloudflare R2
# STORAGE_PROVIDER=s3_compatible
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=pnmc-documents
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true

# --- OPTIONAL ---
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
