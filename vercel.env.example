# =============================================================================
# ENVIRONMENT VARIABLES — production
# =============================================================================
# API: deploy backend/ to Render (see render.yaml) — NOT Vercel serverless.
# Frontend: deploy frontend/ to Vercel.
# =============================================================================

# --- BACKEND (Render) — set in backend service dashboard ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
FRONTEND_URL=https://your-frontend.vercel.app
NODE_ENV=production
PORT=5000
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=pnmc
PAYMENTS_ENABLED=false

# --- FRONTEND (Vercel) — set before build ---
VITE_API_URL=https://your-api.onrender.com/api
