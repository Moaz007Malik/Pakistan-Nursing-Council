# =============================================================================
# VERCEL ENVIRONMENT VARIABLES
# Copy each variable into: Vercel Dashboard → Project → Settings → Environment Variables
# Apply to: Production, Preview, and Development as needed
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — App will not work without these
# -----------------------------------------------------------------------------

# MongoDB Atlas connection string (local MongoDB will NOT work on Vercel)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority

# JWT secrets — generate strong random strings (e.g. openssl rand -base64 64)
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-long-random-secret

# Public URL of your deployed app (custom domain or https://your-project.vercel.app)
FRONTEND_URL=https://your-project.vercel.app

# Node environment
NODE_ENV=production

# -----------------------------------------------------------------------------
# FRONTEND (VITE_ prefix — exposed to browser, safe values only)
# -----------------------------------------------------------------------------

# API base URL — use /api/v1 when frontend + API share the same Vercel deployment
VITE_API_URL=/api/v1

# Socket.io server URL — Vercel serverless does NOT support WebSockets on the API.
# Leave empty to disable real-time, or point to a separate Node host (Railway, Render, etc.)
VITE_SOCKET_URL=

# App display name (optional)
VITE_APP_NAME=PNMC Management System

# -----------------------------------------------------------------------------
# JWT TOKEN EXPIRY (optional)
# -----------------------------------------------------------------------------
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# -----------------------------------------------------------------------------
# FILE STORAGE — use AWS S3 on Vercel (MinIO localhost will NOT work)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=pnmc-documents

# MinIO — only if you host MinIO on a public server (not recommended for Vercel)
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=your-minio-host.com
# MINIO_PORT=443
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=pnmc-documents

# -----------------------------------------------------------------------------
# REDIS (optional — for caching/sessions if you add Redis later)
# Use Upstash Redis on Vercel: https://vercel.com/integrations/upstash
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS (optional)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
EASYPAISA_MERCHANT_ID=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# -----------------------------------------------------------------------------
# NOTIFICATIONS (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMS_API_KEY=
WHATSAPP_API_KEY=

# -----------------------------------------------------------------------------
# AUTO-SET BY VERCEL (do not set manually unless overriding)
# -----------------------------------------------------------------------------
# VERCEL_URL=your-project.vercel.app
# VERCEL_ENV=production
