# =============================================================================
# VERCEL ENVIRONMENT VARIABLES
# =============================================================================

# --- REQUIRED ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
FRONTEND_URL=https://your-project.vercel.app
NODE_ENV=production
VITE_API_URL=/api/v1
VITE_SOCKET_URL=

# --- PAYMENTS ---
# false = all payments auto-complete (no real charge) — good for staging
# true  = real Stripe / Easypaisa / JazzCash
PAYMENTS_ENABLED=false

# Only needed when PAYMENTS_ENABLED=true:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EASYPAISA_MERCHANT_ID=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# --- FILE STORAGE (no AWS required) ---
# Option A: S3-compatible provider (Cloudflare R2, Backblaze B2, hosted MinIO)
STORAGE_PROVIDER=s3_compatible
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=pnmc-documents
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

# Option B: Hosted MinIO (your own VPS)
# STORAGE_PROVIDER=s3_compatible
# S3_ENDPOINT=https://minio.yourdomain.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=pnmc-documents
# S3_FORCE_PATH_STYLE=true

# Option C: AWS S3 (only if you want AWS specifically)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=pnmc-documents

# NOT supported on Vercel: STORAGE_PROVIDER=local or minio on localhost

# --- OPTIONAL ---
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
REDIS_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
