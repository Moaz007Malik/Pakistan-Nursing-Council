# Copy to backend/.env

# Local
MONGODB_URI=mongodb://127.0.0.1:27017/pnmc
# Docker: MONGODB_URI=mongodb://admin:changeme@127.0.0.1:27017/pnmc?authSource=admin
# Atlas SRV: MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority&appName=<appName>

# DNS / SRV (required on Vercel — skip slow SRV lookup on cold start)
MONGODB_DNS_SRV=false
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# Run: npm run mongo:direct-uri — paste output into Vercel as MONGODB_URI_DIRECT
# MONGODB_URI_DIRECT=mongodb://user:pass@host1:27017,host2:27017,host3:27017/pnmc?ssl=true&replicaSet=...
# MONGODB_IPV4_ONLY=false

JWT_SECRET=pnmc-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=pnmc-dev-refresh-secret-change-in-production
NODE_ENV=development
PORT=5000
# Frontend origin for CORS (set to live frontend URL in production)
FRONTEND_URL=http://localhost:3000
# Extra allowed origins (comma-separated), e.g. https://pnmc-pjt.vercel.app
# CORS_ORIGINS=https://pnmc-pjt.vercel.app

STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pnmc

# Legacy local disk (only if STORAGE_PROVIDER=local)
LOCAL_STORAGE_PATH=uploads
PAYMENTS_ENABLED=false

# Seed logins: admin@pnmc.com / Admin@123 (see README)

# --- Vercel (pnmc-backend project) — set in Dashboard → Settings → Environment Variables ---
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority
MONGODB_DNS_SRV=false
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_URI_DIRECT=<run: cd backend && npm run mongo:direct-uri>
FRONTEND_URL=https://pnmc-pjt.vercel.app
# JWT_SECRET=<long-random-secret>
# JWT_REFRESH_SECRET=<different-long-random-secret>
# NODE_ENV=production
# FRONTEND_URL=https://pnmc-pjt.vercel.app
# CORS_ORIGINS=https://pnmc-pjt.vercel.app
# STORAGE_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
# PAYMENTS_ENABLED=false
