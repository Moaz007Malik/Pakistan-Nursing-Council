# Copy to backend/.env

# Local
MONGODB_URI=mongodb://127.0.0.1:27017/pnmc
# Docker: MONGODB_URI=mongodb://admin:changeme@127.0.0.1:27017/pnmc?authSource=admin
# Atlas: MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority

JWT_SECRET=pnmc-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=pnmc-dev-refresh-secret-change-in-production
NODE_ENV=development
PORT=5000

# Frontend origin for CORS + Socket.IO (set to live frontend URL in production)
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=https://pnmc-pjt.vercel.app

STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pnmc

LOCAL_STORAGE_PATH=uploads
PAYMENTS_ENABLED=false

# Seed logins: admin@pnmc.com / Admin@123 (see README)

# --- Production (Render / Railway / Docker) ---
# NODE_ENV=production
# PORT=5000
# MONGODB_URI=mongodb+srv://...
# FRONTEND_URL=https://pnmc-pjt.vercel.app
# JWT_SECRET=<long-random-secret>
# JWT_REFRESH_SECRET=<different-long-random-secret>
# STORAGE_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
