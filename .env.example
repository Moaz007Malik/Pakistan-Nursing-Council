# Copy to backend/.env — see backend/.env.example for full list

MONGODB_URI=mongodb://127.0.0.1:27017/pnmc
JWT_SECRET=pnmc-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=pnmc-dev-refresh-secret-change-in-production
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=uploads
PAYMENTS_ENABLED=false

# Docker MongoDB (optional): admin / changeme
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# Seed logins (npm run seed):
# admin@pnmc.com / Admin@123
# institution@pnmc.com / Inst@123
# student@pnmc.com / Student@123
