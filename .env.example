# Copy to .env in the project root (single env file for the full-stack app)

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/pnmc
# Atlas: MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pnmc?retryWrites=true&w=majority

# DNS / SRV (optional — only if Atlas SRV lookup fails on your host)
MONGODB_DNS_SRV=true
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# Set to true if IPv6 causes connection issues
MONGODB_IPV4_ONLY=false

# --- Auth ---
JWT_SECRET=pnmc-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=pnmc-dev-refresh-secret-change-in-production

# --- Server ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=

# --- Storage ---
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pnmc
LOCAL_STORAGE_PATH=uploads

# --- Payments ---
PAYMENTS_ENABLED=false

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_NAME=PNMC Management System

# Seed logins: admin@pnmc.com / Admin@123 (run: npm run seed)
