# Copy to .env in the project root (single env file for the full-stack app)

# --- JSON database ---
# All data is stored in JSON files under ./data (one file per collection)
# Run `npm run seed` once to populate demo data
# DATA_DIR=./data

# --- Auth ---
JWT_SECRET=pnmc-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=pnmc-dev-refresh-secret-change-in-production

# --- Server ---
# Do not set NODE_ENV in .env — Next.js manages it (build=production, dev=development)
PORT=3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=

# --- Storage ---
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pnmc
LOCAL_STORAGE_PATH=uploads

# --- Payments ---
PAYMENTS_ENABLED=false

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_NAME=PNMC Management System

# Seed logins: admin@pnmc.com / Admin@123 (run: npm run seed)
