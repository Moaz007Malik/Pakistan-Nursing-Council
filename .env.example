# =============================================================================
# LOCAL DEVELOPMENT (Docker / npm run dev)
# For Vercel deployment variables, see: vercel.env.example
# =============================================================================

# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGODB_URI=mongodb://admin:changeme@localhost:27017/pnmc?authSource=admin

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# -----------------------------------------------------------------------------
# FILE STORAGE — you do NOT need AWS
# -----------------------------------------------------------------------------
# Options:
#   local         = saves files to disk (simplest for dev; not for Vercel)
#   minio         = self-hosted S3-compatible storage (included in docker-compose)
#   s3_compatible = Cloudflare R2, Backblaze B2, DigitalOcean Spaces, hosted MinIO
#   s3            = AWS S3 only
#
# Why MinIO? It's a free, self-hosted S3-compatible server in docker-compose so you
# can store documents locally without any cloud account — same API as AWS S3.
STORAGE_PROVIDER=minio

# MinIO (default — runs via docker-compose, no AWS needed)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pnmc-documents
MINIO_USE_SSL=false

# Local disk storage (alternative for dev — set STORAGE_PROVIDER=local)
# LOCAL_STORAGE_PATH=uploads

# S3-compatible cloud (no AWS — e.g. Cloudflare R2, Backblaze B2)
# STORAGE_PROVIDER=s3_compatible
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=pnmc-documents
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true

# AWS S3 (only if you specifically want AWS)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=pnmc-documents

# -----------------------------------------------------------------------------
# PAYMENTS — enable or disable real payment gateways
# -----------------------------------------------------------------------------
# false = bypass mode: all payments auto-complete (no real charge) — default for dev
# true  = live mode: Stripe / Easypaisa / JazzCash must be configured
PAYMENTS_ENABLED=false

# Payment gateways (only used when PAYMENTS_ENABLED=true)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EASYPAISA_MERCHANT_ID=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# Redis
REDIS_URL=redis://localhost:6379

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_API_KEY=
WHATSAPP_API_KEY=

# App
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Frontend (copy to frontend/.env.local)
# VITE_API_URL=/api/v1
# VITE_SOCKET_URL=http://localhost:5000
